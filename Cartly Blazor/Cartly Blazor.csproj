      <_ContentIncludedByDefault Remove="Pages\Login\Cliente\RegisterCliente.razor" />
      <_ContentIncludedByDefault Remove="Pages\Login\LoginPage.razor" />
      <_ContentIncludedByDefault Remove="Pages\Admin\PriceRecords\PriceRecords.razor" />
      <_ContentIncludedByDefault Remove="Pages\Admin\Dashboard\Dashboard.razor" />
      <_ContentIncludedByDefault Remove="Pages\Admin\Products\Products.razor" />
      <_ContentIncludedByDefault Remove="Pages\Admin\Stats\Stats.razor" />
      <_ContentIncludedByDefault Remove="Pages\Admin\Stores\Stores.razor" />
      <_ContentIncludedByDefault Remove="Pages\Admin\Users\Users.razor" />
    </ItemGroup>

</Project>
