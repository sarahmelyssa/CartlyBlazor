@page "/admin/registos"
@page "/admin/pricerecords"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

@using Supabase.Postgrest.Attributes
@using Supabase.Postgrest.Models
@using static Supabase.Postgrest.Constants

@inject Cartly_Blazor.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject Supabase.Client Supabase

<div class="admin-container">

    <div class="admin-page-header">
        <div>
            <h2 class="admin-title">Registos de Preço</h2>
            <p class="admin-subtitle">Gestão dos registos de preço da plataforma.</p>
        </div>

        <button class="login-btn" @onclick="LoadPriceRecords">
            Atualizar
        </button>
    </div>

    <div class="admin-stats-bar">
        <div class="admin-stat">
            <span>Total</span>
            <strong>@priceRecords.Count</strong>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="auth-message success-message">
            @successMessage
        </div>
    }

    @if (isLoading)
    {
        <div class="admin-empty-state">
            <h3>A carregar...</h3>
            <p>A procurar registos de preço...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="auth-message error-message">
            @errorMessage
        </div>
    }
    else if (priceRecords.Count == 0)
    {
        <div class="admin-empty-state">
            <h3>👀 Nada aqui ainda</h3>
            <p>Não existem registos na tabela <b>registo_preco</b>.</p>
            <span>Se no dashboard aparece vazio, pode ser falta de dados ou RLS.</span>
        </div>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                <tr>
                    <th>#</th>
                    <th>Produto ID</th>
                    <th>Loja ID</th>
                    <th>Valor</th>
                    <th>Moeda</th>
                    <th>Credibilidade</th>
                    <th>Data</th>
                    <th>Estado</th>
                    <th>Utilizador</th>
                    <th>Ações</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var item in priceRecords.Select((value, index) => new { value, index }))
                {
                    <tr>
                        <td>@(item.index + 1)</td>
                        <td>@item.value.ProdutoId</td>
                        <td>@item.value.LojaId</td>
                        <td>@item.value.Valor.ToString("0.00")</td>
                        <td>@item.value.Moeda</td>
                        <td>@item.value.GrauCredibilidade</td>
                        <td>@item.value.DataRegisto.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="status-badge @(GetEstadoClass(item.value.Estado))">
                                @item.value.Estado
                            </span>
                        </td>
                        <td>@(item.value.UtilizadorId?.ToString()[..8] ?? "-")</td>
                        <td>
                            <div class="action-buttons">
                                <button class="mini-action-btn confirm-btn"
                                        disabled="@IsEstado(item.value.Estado, "confirmado")"
                                        @onclick='() => UpdateEstado(item.value.Id, "confirmado")'>
                                    Confirmar
                                </button>

                                <button class="mini-action-btn reject-btn"
                                        disabled="@IsEstado(item.value.Estado, "rejeitado")"
                                        @onclick='() => UpdateEstado(item.value.Id, "rejeitado")'>
                                    Rejeitar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<AdminPriceRecordRow> priceRecords = new();
    private bool isLoading = true;
    private string errorMessage = "";
    private string successMessage = "";

    private const string AdminEmail = "sarahmelyssaramos@gmail.com";

    protected override async Task OnInitializedAsync()
    {
        var user = AuthService.GetCurrentUser();

        if (user == null)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (user.Email?.ToLower() != AdminEmail)
        {
            Navigation.NavigateTo("/cliente", true);
            return;
        }

        await LoadPriceRecords();
    }

    private async Task LoadPriceRecords()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        try
        {
            var response = await Supabase
                .From<AdminPriceRecordRow>()
                .Select("*")
                .Get();

            priceRecords = response.Models
                .OrderByDescending(r => r.DataRegisto)
                .ToList();

            Console.WriteLine("PRICE RECORDS: " + priceRecords.Count);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar registos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateEstado(long registoId, string novoEstado)
    {
        errorMessage = "";
        successMessage = "";

        try
        {
            var current = priceRecords.FirstOrDefault(r => r.Id == registoId);

            if (current == null)
            {
                errorMessage = "Registo não encontrado.";
                return;
            }

            current.Estado = novoEstado;

            await Supabase
                .From<AdminPriceRecordRow>()
                .Filter("id", Operator.Equals, registoId)
                .Set(x => x.Estado, novoEstado)
                .Update();

            successMessage = $"Registo {registoId} atualizado para '{novoEstado}'.";
            await LoadPriceRecords();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao atualizar estado: {ex.Message}";
        }
    }

    private static string GetEstadoClass(string? estado)
    {
        var normalized = estado?.Trim().ToLower() ?? "";

        return normalized switch
        {
            "confirmado" => "status-confirmado",
            "pendente" => "status-pendente",
            "rejeitado" => "status-rejeitado",
            _ => "status-default"
        };
    }

    private static bool IsEstado(string? estado, string expected)
    {
        return string.Equals(
            estado?.Trim(),
            expected,
            StringComparison.OrdinalIgnoreCase
        );
    }

    [Table("registo_preco")]
    public class AdminPriceRecordRow : BaseModel
    {
        [PrimaryKey("id", false)]
        [Column("id")]
        public long Id { get; set; }

        [Column("produto_id")]
        public long ProdutoId { get; set; }

        [Column("loja_id")]
        public long LojaId { get; set; }

        [Column("valor")]
        public decimal Valor { get; set; }

        [Column("moeda")]
        public string Moeda { get; set; } = "";

        [Column("grau_credibilidade")]
        public int GrauCredibilidade { get; set; }

        [Column("data_registo")]
        public DateTime DataRegisto { get; set; }

        [Column("estado")]
        public string Estado { get; set; } = "";

        [Column("utilizador_id")]
        public Guid? UtilizadorId { get; set; }
    }
}