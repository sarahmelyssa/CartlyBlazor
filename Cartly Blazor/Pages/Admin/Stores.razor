@page "/admin/lojas"
@page "/admin/stores"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

@using Supabase.Postgrest.Attributes
@using Supabase.Postgrest.Models

@inject Cartly_Blazor.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject Supabase.Client Supabase

<div class="admin-container">

    <div class="admin-page-header">
        <div>
            <h2 class="admin-title">Lojas</h2>
            <p class="admin-subtitle">Gestão das lojas da plataforma.</p>
        </div>

        <button class="login-btn" @onclick="LoadStores">
            Atualizar
        </button>
    </div>

    <div class="admin-stats-bar">
        <div class="admin-stat">
            <span>Total</span>
            <strong>@stores.Count</strong>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="admin-empty-state">
            <h3>A carregar...</h3>
            <p>A procurar lojas...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="auth-message error-message">
            @errorMessage
        </div>
    }
    else if (stores.Count == 0)
    {
        <div class="admin-empty-state">
            <h3>👀 Nada aqui ainda</h3>
            <p>Não existem lojas na tabela <b>loja</b>.</p>
            <span>Se o dashboard mostra lojas e aqui está vazio, vê o RLS desta tabela.</span>
        </div>
    }
    else
    {
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                <tr>
                    <th>#</th>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Google Maps</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var item in stores.Select((value, index) => new { value, index }))
                {
                    <tr>
                        <td>@(item.index + 1)</td>
                        <td>@item.value.Id</td>
                        <td>@(string.IsNullOrWhiteSpace(item.value.Nome) ? "-" : item.value.Nome)</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(item.value.GoogleMapsLink))
                            {
                                <span class="table-muted">Sem link</span>
                            }
                            else
                            {
                                <a href="@item.value.GoogleMapsLink" target="_blank" class="table-link">
                                    Ver mapa
                                </a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<AdminStoreRow> stores = new();
    private bool isLoading = true;
    private string errorMessage = "";

    private const string AdminEmail = "sarahmelyssaramos@gmail.com";

    protected override async Task OnInitializedAsync()
    {
        var user = AuthService.GetCurrentUser();

        if (user == null)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (user.Email?.ToLower() != AdminEmail)
        {
            Navigation.NavigateTo("/cliente", true);
            return;
        }

        await LoadStores();
    }

    private async Task LoadStores()
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            var response = await Supabase
                .From<AdminStoreRow>()
                .Select("*")
                .Get();

            stores = response.Models
                .OrderBy(s => s.Nome)
                .ToList();

            Console.WriteLine("STORES: " + stores.Count);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar lojas: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    [Table("loja")]
    public class AdminStoreRow : BaseModel
    {
        [PrimaryKey("id", false)]
        [Column("id")]
        public long Id { get; set; }

        [Column("nome")]
        public string? Nome { get; set; }

        [Column("google_maps_link")]
        public string? GoogleMapsLink { get; set; }
    }
}