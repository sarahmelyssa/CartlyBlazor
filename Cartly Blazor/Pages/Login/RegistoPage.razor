@page "/register"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@inject Cartly_Blazor.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">
        
        <a href="javascript:history.back()" class="back-arrow">←</a>

        <div class="login-header">
            <h1>Criar conta</h1>
            <p>Cria a tua conta para guardar favoritos e comparar preços</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-message @(isSuccess ? "success-message" : "error-message")">
                @message
            </div>
        }

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="registerForm" class="login-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Nome</label>
                <InputText @bind-Value="registerModel.Nome" class="form-input" placeholder="Ex.: João" />                <ValidationMessage For="@(() => registerModel.Nome)" />
            </div>

            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="registerModel.Username" class="form-input" placeholder="Ex.: joao123" />
                <ValidationMessage For="@(() => registerModel.Username)" />
            </div>

            <div class="form-group">
                <label>Telefone</label>
                <InputText @bind-Value="registerModel.Telefone" class="form-input" placeholder="Ex.: 912345678" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="registerModel.Email" class="form-input" placeholder="Ex.: exemplo@mail.com" />
                <ValidationMessage For="@(() => registerModel.Email)" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="registerModel.Password" type="password" class="form-input" placeholder="********" />
                <ValidationMessage For="@(() => registerModel.Password)" />
            </div>

            <div class="form-group">
                <label>Confirmar Password</label>
                <InputText @bind-Value="registerModel.ConfirmPassword" type="password" class="form-input" placeholder="********" />
                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" />
            </div>

            <button type="submit" class="login-button" disabled="@isSubmitting">
                @(isSubmitting ? "A criar..." : "Criar conta")
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Já tens conta? </span>
            <a href="/login">Entrar</a>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string message = "";
    private bool isSuccess = false;
    private bool isSubmitting = false;

    private async Task HandleRegister()
    {
        if (isSubmitting)
            return;

        message = "";
        isSuccess = false;

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            message = "As palavras-passe não coincidem.";
            return;
        }

        try
        {
            isSubmitting = true;

            var result = await AuthService.RegisterAsync(
                registerModel.Nome,
                registerModel.Username,
                registerModel.Email,
                registerModel.Password,
                registerModel.Telefone
            );

            isSuccess = result.Success;
            message = result.Message;

            if (result.Success)
            {
                Navigation.NavigateTo("/login", true);
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            message = $"Erro inesperado: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterModel
    {
        [Required(ErrorMessage = "O nome é obrigatório.")]
        public string Nome { get; set; } = "";

        [Required(ErrorMessage = "O username é obrigatório.")]
        public string Username { get; set; } = "";

        public string Telefone { get; set; } = "";

        [Required(ErrorMessage = "O email é obrigatório.")]
        [EmailAddress(ErrorMessage = "Email inválido.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "A palavra-passe é obrigatória.")]
        [MinLength(6, ErrorMessage = "A palavra-passe deve ter pelo menos 6 caracteres.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "A confirmação da palavra-passe é obrigatória.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
