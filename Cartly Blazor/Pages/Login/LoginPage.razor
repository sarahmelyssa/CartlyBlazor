@page "/login"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@inject Cartly_Blazor.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">

        <div class="login-header">
            <h1>Login</h1>
            <p>Entra na tua conta para continuar</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-message @(isSuccess ? "success-message" : "error-message")">
                @message
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="loginForm" class="login-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="loginModel.Email"
                           class="form-input"
                           placeholder="Ex.: exemplo@mail.com" />
                <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="loginModel.Password"
                           type="password"
                           class="form-input"
                           placeholder="********" />
                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <button type="submit" class="login-button" disabled="@isSubmitting">
                @(isSubmitting ? "A entrar..." : "Entrar")
            </button>
        </EditForm>

        <div class="login-links">
            <p>
                Esqueceste-te da password?
                <a href="/recuperar-password">Recupera-a aqui</a>
            </p>

            <p>
                Novo por cá?
                <a href="/register">Criar Conta</a>
            </p>
        </div>

    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string message = "";
    private bool isSuccess = false;
    private bool isSubmitting = false;

    private const string AdminEmail = "sarahmelyssaramos@gmail.com";

    private async Task HandleLogin()
    {
        if (isSubmitting)
            return;

        message = "";
        isSuccess = false;

        try
        {
            isSubmitting = true;

            var result = await AuthService.LoginAsync(
                loginModel.Email,
                loginModel.Password
            );

            isSuccess = result.Success;
            message = result.Message;

            if (result.Success)
            {
                var email = loginModel.Email.Trim().ToLower();

                if (email == AdminEmail)
                    Navigation.NavigateTo("/admin", true);
                else
                    Navigation.NavigateTo("/", true);
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            message = $"Erro inesperado: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "O email é obrigatório.")]
        [EmailAddress(ErrorMessage = "Email inválido.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "A palavra-passe é obrigatória.")]
        public string Password { get; set; } = "";
    }
}