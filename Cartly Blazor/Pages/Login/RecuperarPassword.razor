@page "/recuperar-password"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations

@inject Cartly_Blazor.Services.AuthService AuthService

<div class="login-page">
    <div class="login-card">

        <a href="/login" class="back-arrow">←</a>

        <div class="login-header">
            <h1>Recuperar password</h1>
            <p>Vamos enviar um email para redefinires a tua password</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-message @(isSuccess ? "success-message" : "error-message")">
                @message
            </div>
        }

        <EditForm Model="@model" OnValidSubmit="HandleRecover" class="login-form">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="model.Email" class="form-input" placeholder="Ex.: exemplo@mail.com" />
                <ValidationMessage For="@(() => model.Email)" />
            </div>

            <button type="submit" class="login-button" disabled="@isSubmitting">
                @(isSubmitting ? "A enviar..." : "Enviar email")
            </button>
        </EditForm>

    </div>
</div>

@code {
    private RecoverModel model = new();
    private string message = "";
    private bool isSuccess = false;
    private bool isSubmitting = false;

    private async Task HandleRecover()
    {
        if (isSubmitting)
            return;

        try
        {
            isSubmitting = true;

            var result = await AuthService.RecoverPassword(model.Email);

            isSuccess = result.Success;
            message = result.Message;
        }
        catch (Exception ex)
        {
            isSuccess = false;
            message = $"Erro: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RecoverModel
    {
        [Required(ErrorMessage = "Email obrigatório")]
        [EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = "";
    }
}
