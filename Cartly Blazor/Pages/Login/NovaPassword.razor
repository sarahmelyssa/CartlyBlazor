@page "/nova-password"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations

@inject Supabase.Client Supabase
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <h1>Nova password</h1>
            <p>Define a tua nova palavra-passe</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-message @(isSuccess ? "success-message" : "error-message")">
                @message
            </div>
        }

        <EditForm Model="@model" OnValidSubmit="HandleReset" class="login-form">
            <DataAnnotationsValidator />

            <div class="form-group">
    <label>Nova password</label>
    <div class="password-field">
        <InputText @bind-Value="model.Password"
                   type="@(showPassword ? "text" : "password")"
                   class="form-input"
                   placeholder="********" />
        <span class="toggle-password" @onclick="() => showPassword = !showPassword"></span>
    </div>
    <ValidationMessage For="@(() => model.Password)" />
</div>

    <div class="form-group">
        <label>Confirmar password</label>
        <div class="password-field">
            <InputText @bind-Value="model.ConfirmPassword"
                    type="@(showConfirmPassword ? "text" : "password")"
                    class="form-input"
                    placeholder="********" />
            <span class="toggle-password" @onclick="() => showConfirmPassword = !showConfirmPassword">👁</span>
        </div>
        <ValidationMessage For="@(() => model.ConfirmPassword)" />
    </div>

            <button type="submit" class="login-button" disabled="@isSubmitting">
                @(isSubmitting ? "A guardar..." : "Guardar nova password")
            </button>
        </EditForm>
    </div>
</div>

@code {

    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private ResetModel model = new();
    private string message = "";
    private bool isSuccess = false;
    private bool isSubmitting = false;

    private string? accessToken;
    private string? refreshToken;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = new Uri(Navigation.Uri);
            var fragment = uri.Fragment;

            if (!string.IsNullOrWhiteSpace(fragment))
            {
                var clean = fragment.TrimStart('#');
                var parts = clean.Split('&', StringSplitOptions.RemoveEmptyEntries);

                foreach (var part in parts)
                {
                    var kv = part.Split('=', 2);
                    if (kv.Length != 2)
                        continue;

                    var key = Uri.UnescapeDataString(kv[0]);
                    var value = Uri.UnescapeDataString(kv[1]);

                    if (key == "access_token")
                        accessToken = value;

                    if (key == "refresh_token")
                        refreshToken = value;
                }
            }

            if (string.IsNullOrWhiteSpace(accessToken) || string.IsNullOrWhiteSpace(refreshToken))
            {
                message = "Link inválido ou expirado.";
                isSuccess = false;
                return;
            }

            await Supabase.Auth.SetSession(accessToken, refreshToken);
        }
        catch (Exception ex)
        {
            message = $"Erro ao preparar recuperação: {ex.Message}";
            isSuccess = false;
        }
    }

    private async Task HandleReset()
    {
        if (isSubmitting)
            return;

        if (model.Password != model.ConfirmPassword)
        {
            isSuccess = false;
            message = "As passwords não coincidem.";
            return;
        }

        try
        {
            isSubmitting = true;
            message = "";

            await Supabase.Auth.Update(
                new Supabase.Gotrue.UserAttributes
                {
                    Password = model.Password
                }
            );

            isSuccess = true;
            message = "Password alterada com sucesso.";

            await Task.Delay(1200);
            Navigation.NavigateTo("/login", true);
        }
        catch (Exception ex)
        {
            isSuccess = false;
            message = $"Erro ao alterar password: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class ResetModel
    {
        [Required(ErrorMessage = "A nova password é obrigatória.")]
        [MinLength(6, ErrorMessage = "A password deve ter pelo menos 6 caracteres.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirma a nova password.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
