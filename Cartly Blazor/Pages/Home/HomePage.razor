@page "/"
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Web

<div class="home-container">

    <!-- HERO -->
    <section class="hero-section">
        <h1>Compare preços de forma rápida e inteligente</h1>
        <p>
            Descubra rapidamente onde os produtos estão mais baratos e consulte detalhes antes de comprar.
        </p>

        <div class="search-wrapper modern-search">
            <input class="search-input modern-search-input"
                placeholder="Pesquisar produtos..."
                @bind="searchText"
                @bind:event="oninput"
                @onkeydown="HandleKeyDown" />

            <button type="button" class="search-icon-btn" @onclick="Pesquisar" aria-label="Pesquisar">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="7" stroke="white" stroke-width="2.5" />
                    <path d="M20 20L16.65 16.65" stroke="white" stroke-width="2.5" stroke-linecap="round" />
                </svg>
            </button>
        </div>

        <div style="margin-top:15px; display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
            <button class="btn-cartly secondary-btn small-btn"
                    @onclick='() => Navigation.NavigateTo("/precos?search=Água")'>Água</button>

            <button class="btn-cartly secondary-btn small-btn"
                    @onclick='() => Navigation.NavigateTo("/precos?search=Arroz")'>Arroz</button>

            <button class="btn-cartly secondary-btn small-btn"
                    @onclick='() => Navigation.NavigateTo("/precos?search=Atum")'>Atum</button>

            <button class="btn-cartly secondary-btn small-btn"
                    @onclick='() => Navigation.NavigateTo("/precos?search=Café")'>Café</button>
        </div>
    </section>

    <!-- CATEGORIAS -->
    <h3 class="section-title">Explorar categorias</h3>

    <div class="categories-grid">
    <div class="category-card" @onclick='() => Navigation.NavigateTo("/precos?search=Água")'>
        <div class="category-icon">
            <img src="coffee.svg" alt="Bebidas" />
        </div>
        <h4>Bebidas</h4>
        <span>Água, sumos e refrigerantes</span>
    </div>

    <div class="category-card" @onclick='() => Navigation.NavigateTo("/precos?search=Arroz")'>
        <div class="category-icon">
            <img src="package.svg" alt="Mercearia" />
        </div>
        <h4>Mercearia</h4>
        <span>Arroz, massa e essenciais</span>
    </div>

    <div class="category-card" @onclick='() => Navigation.NavigateTo("/precos?search=Atum")'>
        <div class="category-icon">
            <img src="shopping-bag.svg" alt="Conservas" />
        </div>
        <h4>Conservas</h4>
        <span>Atum, feijão e mais</span>
    </div>

    <div class="category-card" @onclick='() => Navigation.NavigateTo("/precos?search=Café")'>
        <div class="category-icon">
            <img src="milk.svg" alt="Pequeno-almoço" />
        </div>
        <h4>Pequeno-almoço</h4>
        <span>Café, cereais e bolachas</span>
    </div>
</div>

    <!-- PRODUTO DESTAQUE -->
    <!-- PRODUTOS EM DESTAQUE -->
