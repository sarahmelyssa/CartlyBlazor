    <div class="quick-product-card" @onclick='() => Navigation.NavigateTo("/precos?search=Biscoff")'>
        <div class="quick-product-image">
            <img src="biscoff.jpg" alt="Bolachas Biscoff" />
        </div>
        <div class="quick-product-body">
            <h4>Bolachas Biscoff</h4>
            <p>Descobrir rapidamente onde comprar.</p>
            <button type="button" class="quick-product-btn">Ver preços</button>
