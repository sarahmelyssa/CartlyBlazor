            <button type="button" class="quick-product-btn">Ver preços</button>
        </div>
    </div>

</div>

</div>

@code {
    private string searchText = "";

    private void Pesquisar()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            Navigation.NavigateTo("/precos");
            return;
        }

        Navigation.NavigateTo($"/precos?search={Uri.EscapeDataString(searchText.Trim())}");
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            Pesquisar();
    }
    
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
            return;

        var uri = new Uri(Navigation.Uri);
        var fragment = uri.Fragment;

        if (!string.IsNullOrWhiteSpace(fragment) &&
            fragment.Contains("access_token=") &&
            fragment.Contains("type=recovery"))
        {
            Navigation.NavigateTo($"/nova-password{fragment}", true);
        }
    }
}
