@inherits LayoutComponentBase
@inject Cartly_Blazor.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="layout-shell">
    <header class="site-header">
       <div class="site-header-inner">
    <div class="header-left">
        <span style="font-size: 28px; line-height: 1; margin-right: 32px; color: #d81b60; display: inline-block;">☰</span>
        <a href="@GetHomeRoute()" class="site-brand">Cartly</a>
    </div>

    <nav class="site-nav">
        @if (isLoggedIn)
        {
            @if (isAdmin)
            {
                <div class="header-actions">
                    <a href="/admin/users" class="login-btn">Utilizadores</a>
                    <a href="/admin/produtos" class="login-btn">Produtos</a>
                    <a href="/admin/lojas" class="login-btn">Lojas</a>
                    <a href="/admin/registos" class="login-btn">Registos</a>

                    <button type="button" class="login-btn logout-btn" @onclick="Logout">
                        Logout
                    </button>
                </div>
            }
            else
            {
                <div class="header-actions">
                    <a href="/favoritos" class="login-btn">Favoritos</a>
                    <a href="/perfil" class="login-btn">Perfil</a>

                    <button type="button" class="login-btn logout-btn" @onclick="Logout">
                        Logout
                    </button>
                </div>
            }
        }
        else
        {
            <div class="header-right-public">
                <a href="/login" class="login-btn">Entrar | Registo</a>

                <a href="/login" class="profile-icon">
                    <img src="/user.svg" alt="perfil" width="50" height="50" />
    </a>
            </div>
        }
    </nav>
</div>
    </header>

    <main class="site-main">
        @Body
    </main>
</div>

@code {
    private bool isLoggedIn;
    private bool isAdmin;

    private const string AdminEmail = "sarahmelyssaramos@gmail.com";

    protected override void OnInitialized()
    {
        AtualizarEstado();
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        AtualizarEstado();
        InvokeAsync(StateHasChanged);
    }

    private void AtualizarEstado()
    {
        var user = AuthService.GetCurrentUser();
        isLoggedIn = user != null;

        var email = user?.Email?.Trim().ToLower() ?? "";
        isAdmin = email == AdminEmail;
    }

    private async Task Logout()
    {
        Console.WriteLine("CLIQUEI NO LOGOUT");
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
    
    private string GetHomeRoute()
    {
        if (!isLoggedIn){
            return "/";
        }
        return isAdmin ? "/admin" : "/";
    }
    

}
    